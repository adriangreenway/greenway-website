---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Reviews" description="What our couples and planners say">

  <!-- Inner Page Hero -->
  <section class="rev-hero">
    <span class="rev-label" data-reveal>Reviews</span>
    <h1 class="rev-hero__title" data-reveal data-reveal-delay="1">What couples are saying</h1>
  </section>

  <!-- Reviews -->
  <section class="rev-reviews">
    <div class="rev-reviews__inner">

      <!-- PLACEHOLDER: Replace with real review -->
      <div class="rev-review">
        <blockquote class="rev-review__quote" data-reveal>Review coming soon</blockquote>
        <p class="rev-review__attribution" data-reveal data-reveal-delay="1">Couple Name · Venue</p>
      </div>

      <hr class="rev-review__divider" />

      <!-- PLACEHOLDER: Replace with real review -->
      <div class="rev-review">
        <blockquote class="rev-review__quote" data-reveal>Review coming soon</blockquote>
        <p class="rev-review__attribution" data-reveal data-reveal-delay="1">Couple Name · Venue</p>
      </div>

      <hr class="rev-review__divider" />

      <!-- PLACEHOLDER: Replace with real review -->
      <div class="rev-review">
        <blockquote class="rev-review__quote" data-reveal>Review coming soon</blockquote>
        <p class="rev-review__attribution" data-reveal data-reveal-delay="1">Couple Name · Venue</p>
      </div>

    </div>
  </section>

  <!-- CTA -->
  <section class="rev-cta section--dark">
    <div class="rev-cta__inner">
      <h2 class="rev-cta__headline" data-reveal>Check availability for your date</h2>
      <a href="/book" class="rev-cta__button" data-reveal data-reveal-delay="1">Check Availability</a>
    </div>
  </section>

</BaseLayout>

<style is:global>
  /* Hero */
  .rev-hero {
    padding: var(--section-padding) var(--content-padding) 80px;
    padding-top: calc(72px + var(--section-padding));
    text-align: center;
  }

  .rev-hero__title {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: var(--text-page-headline);
    font-weight: 400;
    line-height: var(--line-height-headline);
    color: var(--color-black);
    max-width: 720px;
    margin: 0 auto;
  }

  /* Shared label style */
  .rev-label {
    display: block;
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 3px;
    color: var(--color-dim);
    margin-bottom: var(--space-md);
  }

  /* Reviews section */
  .rev-reviews {
    padding: 0 var(--content-padding) var(--section-padding);
  }

  .rev-reviews__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Individual review */
  .rev-review {
    text-align: center;
    padding: 80px 0;
  }

  .rev-review__quote {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: 24px;
    font-style: italic;
    font-weight: 400;
    line-height: 1.6;
    color: var(--color-black);
    max-width: 720px;
    margin: 0 auto;
  }

  .rev-review__attribution {
    font-family: var(--font-body);
    font-size: 12px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: var(--color-dim);
    margin-top: 32px;
  }

  .rev-review__divider {
    border: none;
    border-top: 1px solid rgba(0, 0, 0, 0.08);
    max-width: 120px;
    margin: 0 auto;
  }

  /* CTA */
  .rev-cta {
    padding: var(--section-padding) var(--content-padding);
  }

  .rev-cta__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    text-align: center;
  }

  .rev-cta__headline {
    font-family: var(--font-display);
    font-optical-sizing: auto;
    font-size: var(--text-section-headline);
    font-weight: 400;
    color: var(--color-cream);
    margin-bottom: var(--space-2xl);
  }

  .rev-cta__button {
    display: inline-block;
    background: var(--color-cream);
    color: var(--color-black);
    font-family: var(--font-body);
    font-size: var(--text-button);
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    padding: 14px 32px;
    border: none;
    border-radius: 0;
    transition: background-color var(--transition-default);
  }

  .rev-cta__button:hover {
    background: #ffffff;
  }

  .rev-cta__button:focus-visible {
    outline: 2px solid var(--color-cream);
    outline-offset: 4px;
  }

  /* Mobile */
  @media (max-width: 767px) {
    .rev-hero {
      padding-top: calc(72px + 80px);
      padding-bottom: 60px;
    }

    .rev-review {
      padding: 60px 0;
    }

    .rev-review__quote {
      font-size: 20px;
    }
  }
</style>
