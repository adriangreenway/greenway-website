---
interface Props {
  variant?: 'light' | 'dark';
}

const { variant = 'light' } = Astro.props;
---

{variant === 'dark' ? (
  <svg viewBox="0 0 440 240" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="The Greenway Band">
    <line x1="150" y1="20" x2="290" y2="20" stroke="#F5F2ED" stroke-width="0.4" opacity="0.3"/>
    <text x="220" y="56" text-anchor="middle" font-family="'Bodoni Moda', serif" font-size="13" fill="#B8B4AC" letter-spacing="10" font-weight="400">THE</text>
    <text x="220" y="116" text-anchor="middle" font-family="'Bodoni Moda', serif" font-size="58" fill="#F5F2ED" letter-spacing="5" font-weight="400">GREENWAY</text>
    <text x="220" y="150" text-anchor="middle" font-family="'Plus Jakarta Sans', sans-serif" font-size="13" fill="#706D66" letter-spacing="14" font-weight="400">BAND</text>
    <line x1="150" y1="174" x2="290" y2="174" stroke="#F5F2ED" stroke-width="0.4" opacity="0.3"/>
    <text x="220" y="208" text-anchor="middle" font-family="'Bodoni Moda', serif" font-size="11" fill="#4A4740" font-style="italic" letter-spacing="1.5">The sound of a great night</text>
  </svg>
) : (
  <svg viewBox="0 0 440 240" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="The Greenway Band">
    <line x1="150" y1="20" x2="290" y2="20" stroke="#0A0A09" stroke-width="0.4" opacity="0.2"/>
    <text x="220" y="56" text-anchor="middle" font-family="'Bodoni Moda', serif" font-size="13" fill="#8a867e" letter-spacing="10" font-weight="400">THE</text>
    <text x="220" y="116" text-anchor="middle" font-family="'Bodoni Moda', serif" font-size="58" fill="#0A0A09" letter-spacing="5" font-weight="400">GREENWAY</text>
    <text x="220" y="150" text-anchor="middle" font-family="'Plus Jakarta Sans', sans-serif" font-size="13" fill="#8a867e" letter-spacing="14" font-weight="400">BAND</text>
    <line x1="150" y1="174" x2="290" y2="174" stroke="#0A0A09" stroke-width="0.4" opacity="0.2"/>
    <text x="220" y="208" text-anchor="middle" font-family="'Bodoni Moda', serif" font-size="11" fill="#aaa" font-style="italic" letter-spacing="1.5">The sound of a great night</text>
  </svg>
)}
