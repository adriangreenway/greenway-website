---
interface Props {
  variant?: 'light' | 'dark';
}

const { variant = 'light' } = Astro.props;
---

{variant === 'light' ? (
  <svg viewBox="0 0 500 110" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="The Greenway Band">
    <text x="250" y="28" text-anchor="middle" font-family="'Bodoni Moda', serif" font-size="11" fill="#8a867e" letter-spacing="8" font-weight="400">THE</text>
    <text x="250" y="72" text-anchor="middle" font-family="'Bodoni Moda', serif" font-size="44" fill="#0A0A09" letter-spacing="4" font-weight="400">GREENWAY</text>
    <text x="250" y="98" text-anchor="middle" font-family="'Plus Jakarta Sans', sans-serif" font-size="11" fill="#8a867e" letter-spacing="12" font-weight="400">BAND</text>
  </svg>
) : (
  <svg viewBox="0 0 500 110" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="The Greenway Band">
    <text x="250" y="28" text-anchor="middle" font-family="'Bodoni Moda', serif" font-size="11" fill="#B8B4AC" letter-spacing="8" font-weight="400">THE</text>
    <text x="250" y="72" text-anchor="middle" font-family="'Bodoni Moda', serif" font-size="44" fill="#F5F2ED" letter-spacing="4" font-weight="400">GREENWAY</text>
    <text x="250" y="98" text-anchor="middle" font-family="'Plus Jakarta Sans', sans-serif" font-size="11" fill="#B8B4AC" letter-spacing="12" font-weight="400">BAND</text>
  </svg>
)}
