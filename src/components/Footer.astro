---
import { siteConfig } from '../config/site';
---

<footer class="footer">
  <div class="footer__inner">
    <!-- Monument-format logo (stacked text, no SVG, no hairlines) -->
    <div class="footer__monument">
      <span class="footer__logo-the">THE</span>
      <span class="footer__logo-greenway">GREENWAY</span>
      <span class="footer__logo-band">BAND</span>
      <p class="footer__descriptor">The sound of a great night</p>
    </div>

    <!-- Social proof venue list -->
    <p class="footer__venues">
      River Oaks Country Club · Houston Country Club · Post Oak Hotel · The Astorian · The Houstonian · The Grand Galvez · Iron Manor · Ashton Gardens · Lakeside Country Club · The Junior League · The Houston Grand Hotel · Windemere Farms · La Colombe d'Or
    </p>

    <!-- Copyright -->
    <div class="footer__copyright">
      &copy; 2026 {siteConfig.name}
    </div>
  </div>
</footer>
