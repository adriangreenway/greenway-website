---
interface Props {
  darkHero?: boolean;
}

const { darkHero = false } = Astro.props;

const navLinks = [
  { title: 'Experience', slug: '/experience' },
  { title: 'Book', slug: '/book' },
];
---

<header class={`header${darkHero ? ' header--dark-hero' : ''}`}>
  <!-- Desktop logo (inline text, not SVG) -->
  <a href="/" class="header__logo header__logo--desktop" aria-label="The Greenway Band — Home">
    <span class="header__logo-the">THE</span>
    <span class="header__logo-greenway">GREENWAY</span>
    <span class="header__logo-band">BAND</span>
  </a>
  <!-- Mobile compact logo -->
  <a href="/" class="header__logo header__logo--mobile" aria-label="The Greenway Band — Home">
    <span class="header__logo-the">THE</span>
    <span class="header__logo-greenway">GREENWAY</span>
    <span class="header__logo-band">BAND</span>
  </a>
  <nav class="header__nav">
    {navLinks.map(page => (
      <a href={page.slug}>{page.title}</a>
    ))}
  </nav>
  <button class="hamburger" aria-label="Open menu" aria-expanded="false">
    <span></span>
    <span></span>
    <span></span>
  </button>
</header>

<div class="mobile-menu">
  <button class="mobile-menu-close" aria-label="Close menu"></button>
  {navLinks.map(page => (
    <a href={page.slug}>{page.title}</a>
  ))}
</div>

<script>
  const header = document.querySelector('.header');
  const isDarkHero = header?.classList.contains('header--dark-hero');

  if (isDarkHero) {
    // On hero pages, transition after scrolling past ~100vh
    window.addEventListener('scroll', () => {
      const scrolled = window.scrollY > window.innerHeight * 0.8;
      header.classList.toggle('header--scrolled', scrolled);
    }, { passive: true });
  } else {
    // On inner pages, immediately show solid background (already default via CSS)
  }

  const hamburger = document.querySelector('.hamburger');
  const closeBtn = document.querySelector('.mobile-menu-close');
  const mobileMenu = document.querySelector('.mobile-menu');
  const toggleMenu = (open: boolean) => {
    mobileMenu?.classList.toggle('mobile-menu--open', open);
    document.body.style.overflow = open ? 'hidden' : '';
    hamburger?.setAttribute('aria-expanded', String(open));
  };
  hamburger?.addEventListener('click', () => toggleMenu(true));
  closeBtn?.addEventListener('click', () => toggleMenu(false));
  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => toggleMenu(false));
  });
</script>
